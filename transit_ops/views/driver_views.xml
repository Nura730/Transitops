<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Driver Tree View ═══ -->
    <record id="view_transit_driver_tree" model="ir.ui.view">
        <field name="name">transit.driver.tree</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <tree string="Drivers" decoration-danger="is_license_expired == True" decoration-warning="status == 'suspended'">
                <field name="name"/>
                <field name="license_number"/>
                <field name="license_category"/>
                <field name="license_expiry"/>
                <field name="license_status_display" string="License Status"/>
                <field name="phone"/>
                <field name="safety_score" widget="progressbar"/>
                <field name="rating"/>
                <field name="total_trips"/>
                <field name="status" widget="badge" decoration-success="status == 'available'" decoration-info="status == 'on_trip'" decoration-muted="status == 'off_duty'" decoration-danger="status == 'suspended'"/>
                <field name="is_license_expired" column_invisible="True"/>
            </tree>
        </field>
    </record>

    <!-- ═══ Driver Form View ═══ -->
    <record id="view_transit_driver_form" model="ir.ui.view">
        <field name="name">transit.driver.form</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <form string="Driver">
                <header>
                    <button name="action_set_available" string="Set Available" type="object" class="btn-primary"
                            invisible="status == 'available'"/>
                    <button name="action_set_off_duty" string="Set Off Duty" type="object" class="btn-secondary"
                            invisible="status in ('off_duty', 'on_trip')"/>
                    <button name="action_suspend" string="Suspend" type="object" class="btn-danger"
                            invisible="status in ('suspended', 'on_trip')" confirm="Are you sure you want to suspend this driver?"/>
                    <field name="status" widget="statusbar" statusbar_visible="available,on_trip,off_duty,suspended"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object" class="oe_stat_button" icon="fa-road">
                            <field name="total_trips" widget="statinfo" string="Trips"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="License Expired!" bg_color="text-bg-danger"
                            invisible="is_license_expired == False"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Driver Full Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Personal Information">
                            <field name="phone" widget="phone"/>
                            <field name="email" widget="email"/>
                            <field name="hours_per_week"/>
                        </group>
                        <group string="License Details">
                            <field name="license_number"/>
                            <field name="license_category"/>
                            <field name="license_expiry"/>
                            <field name="license_status_display" string="License Status"/>
                            <field name="is_license_expired" invisible="1"/>
                        </group>
                    </group>
                    <group string="Performance">
                        <group>
                            <field name="safety_score" widget="progressbar"/>
                        </group>
                        <group>
                            <field name="rating"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Trip History" name="trips">
                            <field name="trip_ids" readonly="1">
                                <tree>
                                    <field name="trip_code"/>
                                    <field name="source"/>
                                    <field name="destination"/>
                                    <field name="vehicle_id"/>
                                    <field name="cargo_weight"/>
                                    <field name="status" widget="badge"/>
                                    <field name="dispatched_at"/>
                                    <field name="completed_at"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══ Driver Kanban View ═══ -->
    <record id="view_transit_driver_kanban" model="ir.ui.view">
        <field name="name">transit.driver.kanban</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="name"/>
                <field name="license_number"/>
                <field name="safety_score"/>
                <field name="rating"/>
                <field name="total_trips"/>
                <field name="status"/>
                <field name="license_status_display"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb8">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span class="o_kanban_record_subtitle text-muted">
                                        License: <field name="license_number"/>
                                    </span>
                                </div>
                                <field name="status" widget="label_selection" options="{'classes': {'available': 'success', 'on_trip': 'info', 'off_duty': 'secondary', 'suspended': 'danger'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>Safety Score: <field name="safety_score"/>%</div>
                                <div>Rating: <field name="rating"/> / 5</div>
                                <div><field name="license_status_display"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span><field name="total_trips"/> trips</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ Driver Search View ═══ -->
    <record id="view_transit_driver_search" model="ir.ui.view">
        <field name="name">transit.driver.search</field>
        <field name="model">transit.driver</field>
        <field name="arch" type="xml">
            <search string="Search Drivers">
                <field name="name"/>
                <field name="license_number"/>
                <filter string="Available" name="available" domain="[('status', '=', 'available')]"/>
                <filter string="On Trip" name="on_trip" domain="[('status', '=', 'on_trip')]"/>
                <filter string="Off Duty" name="off_duty" domain="[('status', '=', 'off_duty')]"/>
                <filter string="Suspended" name="suspended" domain="[('status', '=', 'suspended')]"/>
                <separator/>
                <filter string="License Expired" name="expired" domain="[('is_license_expired', '=', True)]"/>
                <filter string="License Expiring Soon (&lt; 30d)" name="expiring_soon" domain="[('license_days_remaining', '&lt;', 30), ('license_days_remaining', '&gt;', 0)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="groupby_status" context="{'group_by': 'status'}"/>
                    <filter string="License Category" name="groupby_category" context="{'group_by': 'license_category'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ Driver Action ═══ -->
    <record id="action_transit_driver" model="ir.actions.act_window">
        <field name="name">Drivers</field>
        <field name="res_model">transit.driver</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_transit_driver_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add your first driver
            </p>
            <p>
                Register drivers to assign them to trips and track their safety performance.
            </p>
        </field>
    </record>
</odoo>
