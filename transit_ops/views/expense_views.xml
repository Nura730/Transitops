<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Expense Tree View ═══ -->
    <record id="view_transit_expense_tree" model="ir.ui.view">
        <field name="name">transit.expense.tree</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <tree string="Expenses" editable="bottom">
                <field name="date"/>
                <field name="vehicle_id"/>
                <field name="vehicle_registration"/>
                <field name="expense_type"/>
                <field name="amount" sum="Total Amount"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- ═══ Expense Form View ═══ -->
    <record id="view_transit_expense_form" model="ir.ui.view">
        <field name="name">transit.expense.form</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <form string="Expense">
                <sheet>
                    <group>
                        <group string="Expense Details">
                            <field name="vehicle_id" options="{'no_create': True}"/>
                            <field name="expense_type"/>
                            <field name="amount"/>
                            <field name="date"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ Expense Search ═══ -->
    <record id="view_transit_expense_search" model="ir.ui.view">
        <field name="name">transit.expense.search</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <search string="Search Expenses">
                <field name="vehicle_id"/>
                <field name="expense_type"/>
                <filter string="Fuel" name="fuel" domain="[('expense_type', '=', 'fuel')]"/>
                <filter string="Maintenance" name="maintenance" domain="[('expense_type', '=', 'maintenance')]"/>
                <filter string="Toll" name="toll" domain="[('expense_type', '=', 'toll')]"/>
                <filter string="Insurance" name="insurance" domain="[('expense_type', '=', 'insurance')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Vehicle" name="groupby_vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Type" name="groupby_type" context="{'group_by': 'expense_type'}"/>
                    <filter string="Month" name="groupby_month" context="{'group_by': 'date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ Expense Graph ═══ -->
    <record id="view_transit_expense_graph" model="ir.ui.view">
        <field name="name">transit.expense.graph</field>
        <field name="model">transit.expense</field>
        <field name="arch" type="xml">
            <graph string="Expense Breakdown" type="pie">
                <field name="expense_type"/>
                <field name="amount" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ═══ Expense Action ═══ -->
    <record id="action_transit_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">transit.expense</field>
        <field name="view_mode">tree,form,graph</field>
        <field name="search_view_id" ref="view_transit_expense_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Record your first expense
            </p>
            <p>
                Track operational expenses like tolls, insurance, and other costs per vehicle.
            </p>
        </field>
    </record>
</odoo>
