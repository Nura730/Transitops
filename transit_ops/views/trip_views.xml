<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Trip Sequence ═══ -->
    <record id="seq_transit_trip" model="ir.sequence">
        <field name="name">Transit Trip Sequence</field>
        <field name="code">transit.trip</field>
        <field name="prefix">TRP-</field>
        <field name="padding">5</field>
        <field name="number_increment">1</field>
    </record>

    <!-- ═══ Trip Tree View ═══ -->
    <record id="view_transit_trip_tree" model="ir.ui.view">
        <field name="name">transit.trip.tree</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <tree string="Trips" decoration-success="status == 'completed'" decoration-info="status == 'dispatched'" decoration-muted="status == 'cancelled'">
                <field name="trip_code"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="cargo_weight" string="Cargo (kg)"/>
                <field name="distance" string="Distance (km)"/>
                <field name="revenue"/>
                <field name="priority" widget="badge"/>
                <field name="pickup_date"/>
                <field name="status" widget="badge" decoration-success="status == 'completed'" decoration-info="status == 'dispatched'" decoration-muted="status in ('draft', 'cancelled')"/>
            </tree>
        </field>
    </record>

    <!-- ═══ Trip Form View ═══ -->
    <record id="view_transit_trip_form" model="ir.ui.view">
        <field name="name">transit.trip.form</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <form string="Trip">
                <header>
                    <button name="action_dispatch" string="Dispatch Trip" type="object"
                            class="btn-primary" invisible="status != 'draft'"/>
                    <button name="action_complete" string="Complete Trip" type="object"
                            class="btn-success" invisible="status != 'dispatched'"/>
                    <button name="action_cancel" string="Cancel Trip" type="object"
                            class="btn-danger" invisible="status in ('completed', 'cancelled')"
                            confirm="Are you sure you want to cancel this trip?"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object"
                            class="btn-secondary" invisible="status != 'cancelled'"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,dispatched,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="trip_code" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Route">
                            <field name="source"/>
                            <field name="destination"/>
                            <field name="pickup_date"/>
                            <field name="priority"/>
                        </group>
                        <group string="Assignment">
                            <field name="vehicle_id" domain="[('status', '=', 'available')]"
                                   readonly="status != 'draft'"
                                   options="{'no_create': True}"/>
                            <field name="vehicle_max_capacity" string="Vehicle Capacity (kg)"/>
                            <field name="driver_id" domain="[('status', '=', 'available'), ('is_license_expired', '=', False)]"
                                   readonly="status != 'draft'"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group string="Cargo &amp; Financials">
                            <field name="cargo_weight" readonly="status != 'draft'"/>
                            <field name="distance"/>
                            <field name="revenue"/>
                        </group>
                        <group string="Trip Completion" invisible="status != 'dispatched'">
                            <field name="final_odometer"/>
                            <field name="fuel_consumed"/>
                            <field name="fuel_efficiency_trip" string="Fuel Efficiency (km/L)"/>
                        </group>
                    </group>
                    <group string="Timeline" invisible="status == 'draft'">
                        <group>
                            <field name="dispatched_at" readonly="1"/>
                            <field name="completed_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="cancelled_at" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══ Trip Kanban View ═══ -->
    <record id="view_transit_trip_kanban" model="ir.ui.view">
        <field name="name">transit.trip.kanban</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="trip_code"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="cargo_weight"/>
                <field name="status"/>
                <field name="priority"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb8">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="trip_code"/>
                                    </strong>
                                </div>
                                <field name="priority" widget="label_selection" options="{'classes': {'standard': 'secondary', 'high': 'warning', 'urgent': 'danger'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><strong><field name="source"/></strong> → <strong><field name="destination"/></strong></div>
                                <div class="text-muted">
                                    <field name="vehicle_id"/> · <field name="driver_id"/>
                                </div>
                                <div class="text-muted">
                                    Cargo: <field name="cargo_weight"/> kg
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ Trip Search View ═══ -->
    <record id="view_transit_trip_search" model="ir.ui.view">
        <field name="name">transit.trip.search</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <search string="Search Trips">
                <field name="trip_code"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <filter string="Draft" name="draft" domain="[('status', '=', 'draft')]"/>
                <filter string="Dispatched" name="dispatched" domain="[('status', '=', 'dispatched')]"/>
                <filter string="Completed" name="completed" domain="[('status', '=', 'completed')]"/>
                <filter string="Cancelled" name="cancelled" domain="[('status', '=', 'cancelled')]"/>
                <separator/>
                <filter string="High Priority" name="high_priority" domain="[('priority', 'in', ['high', 'urgent'])]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="groupby_status" context="{'group_by': 'status'}"/>
                    <filter string="Vehicle" name="groupby_vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter string="Driver" name="groupby_driver" context="{'group_by': 'driver_id'}"/>
                    <filter string="Priority" name="groupby_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ Trip Graph View ═══ -->
    <record id="view_transit_trip_graph" model="ir.ui.view">
        <field name="name">transit.trip.graph</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <graph string="Trip Analytics" type="bar">
                <field name="status" type="row"/>
                <field name="revenue" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ═══ Trip Pivot View ═══ -->
    <record id="view_transit_trip_pivot" model="ir.ui.view">
        <field name="name">transit.trip.pivot</field>
        <field name="model">transit.trip</field>
        <field name="arch" type="xml">
            <pivot string="Trip Analysis">
                <field name="status" type="col"/>
                <field name="vehicle_id" type="row"/>
                <field name="revenue" type="measure"/>
                <field name="distance" type="measure"/>
                <field name="cargo_weight" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══ Trip Action ═══ -->
    <record id="action_transit_trip" model="ir.actions.act_window">
        <field name="name">Trip Dispatcher</field>
        <field name="res_model">transit.trip</field>
        <field name="view_mode">kanban,tree,form,graph,pivot</field>
        <field name="search_view_id" ref="view_transit_trip_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first trip
            </p>
            <p>
                Plan, assign and dispatch trips in a guided workflow. Select source, destination, vehicle, driver, and cargo.
            </p>
        </field>
    </record>

    <!-- ═══ Trip Report Action (for Reports menu) ═══ -->
    <record id="action_transit_trip_report" model="ir.actions.act_window">
        <field name="name">Reports &amp; Analytics</field>
        <field name="res_model">transit.trip</field>
        <field name="view_mode">graph,pivot,tree</field>
        <field name="search_view_id" ref="view_transit_trip_search"/>
        <field name="context">{'search_default_completed': 1}</field>
    </record>
</odoo>
