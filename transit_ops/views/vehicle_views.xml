<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══ Vehicle Tree View ═══ -->
    <record id="view_transit_vehicle_tree" model="ir.ui.view">
        <field name="name">transit.vehicle.tree</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <tree string="Vehicles" decoration-danger="status == 'retired'" decoration-warning="status == 'in_shop'" decoration-success="status == 'available'" decoration-info="status == 'on_trip'">
                <field name="registration_number"/>
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="max_capacity" widget="float" string="Capacity (kg)"/>
                <field name="odometer" widget="float" string="Odometer (km)"/>
                <field name="fuel_level" widget="progressbar"/>
                <field name="location"/>
                <field name="status" widget="badge" decoration-success="status == 'available'" decoration-info="status == 'on_trip'" decoration-warning="status == 'in_shop'" decoration-danger="status == 'retired'"/>
            </tree>
        </field>
    </record>

    <!-- ═══ Vehicle Form View ═══ -->
    <record id="view_transit_vehicle_form" model="ir.ui.view">
        <field name="name">transit.vehicle.form</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <button name="action_set_available" string="Set Available" type="object" class="btn-primary"
                            invisible="status == 'available'"/>
                    <button name="action_set_retired" string="Retire Vehicle" type="object" class="btn-secondary"
                            invisible="status in ('retired', 'on_trip')" confirm="Are you sure you want to retire this vehicle?"/>
                    <field name="status" widget="statusbar" statusbar_visible="available,on_trip,in_shop,retired"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_trips" type="object" class="oe_stat_button" icon="fa-road">
                            <field name="trip_count" widget="statinfo" string="Trips"/>
                        </button>
                        <button name="action_view_maintenance" type="object" class="oe_stat_button" icon="fa-wrench">
                            <field name="total_maintenance_cost" widget="statinfo" string="Maintenance"/>
                        </button>
                        <button name="action_view_fuel_logs" type="object" class="oe_stat_button" icon="fa-tint">
                            <field name="total_fuel_cost" widget="statinfo" string="Fuel Cost"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Vehicle Name / Model"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Vehicle Information">
                            <field name="registration_number"/>
                            <field name="vehicle_type"/>
                            <field name="year"/>
                            <field name="max_capacity"/>
                        </group>
                        <group string="Operations">
                            <field name="odometer"/>
                            <field name="fuel_level" widget="progressbar"/>
                            <field name="location"/>
                            <field name="home_depot"/>
                            <field name="next_service_date"/>
                        </group>
                    </group>
                    <group string="Financial">
                        <group>
                            <field name="acquisition_cost" widget="monetary"/>
                            <field name="total_revenue" widget="monetary"/>
                        </group>
                        <group>
                            <field name="operational_cost" widget="monetary"/>
                            <field name="vehicle_roi" widget="float" string="ROI (%)"/>
                            <field name="fuel_efficiency" string="Fuel Eff. (km/L)"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Trips" name="trips">
                            <field name="trip_ids" readonly="1">
                                <tree>
                                    <field name="trip_code"/>
                                    <field name="source"/>
                                    <field name="destination"/>
                                    <field name="driver_id"/>
                                    <field name="cargo_weight"/>
                                    <field name="distance"/>
                                    <field name="revenue"/>
                                    <field name="status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Maintenance" name="maintenance">
                            <field name="maintenance_ids" readonly="1">
                                <tree>
                                    <field name="work_order_code"/>
                                    <field name="description"/>
                                    <field name="maintenance_type"/>
                                    <field name="technician"/>
                                    <field name="cost"/>
                                    <field name="status" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Fuel Logs" name="fuel_logs">
                            <field name="fuel_log_ids" readonly="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="litres"/>
                                    <field name="cost"/>
                                    <field name="station"/>
                                    <field name="driver_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Expenses" name="expenses">
                            <field name="expense_ids" readonly="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="expense_type"/>
                                    <field name="amount"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══ Vehicle Kanban View ═══ -->
    <record id="view_transit_vehicle_kanban" model="ir.ui.view">
        <field name="name">transit.vehicle.kanban</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="status">
                <field name="name"/>
                <field name="registration_number"/>
                <field name="vehicle_type"/>
                <field name="max_capacity"/>
                <field name="odometer"/>
                <field name="fuel_level"/>
                <field name="status"/>
                <field name="location"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb8">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <span class="o_kanban_record_subtitle text-muted">
                                        <field name="registration_number"/>
                                    </span>
                                </div>
                                <field name="status" widget="label_selection" options="{'classes': {'available': 'success', 'on_trip': 'info', 'in_shop': 'warning', 'retired': 'danger'}}"/>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>Type: <field name="vehicle_type"/></div>
                                <div>Capacity: <field name="max_capacity"/> kg</div>
                                <div>Location: <field name="location"/></div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_left">
                                    <span>Fuel: <field name="fuel_level"/>%</span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span><field name="odometer"/> km</span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ Vehicle Search View ═══ -->
    <record id="view_transit_vehicle_search" model="ir.ui.view">
        <field name="name">transit.vehicle.search</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search Vehicles">
                <field name="name"/>
                <field name="registration_number"/>
                <field name="vehicle_type"/>
                <field name="location"/>
                <filter string="Available" name="available" domain="[('status', '=', 'available')]"/>
                <filter string="On Trip" name="on_trip" domain="[('status', '=', 'on_trip')]"/>
                <filter string="In Shop" name="in_shop" domain="[('status', '=', 'in_shop')]"/>
                <filter string="Retired" name="retired" domain="[('status', '=', 'retired')]"/>
                <separator/>
                <filter string="Trucks" name="trucks" domain="[('vehicle_type', '=', 'truck')]"/>
                <filter string="Trailers" name="trailers" domain="[('vehicle_type', '=', 'trailer')]"/>
                <filter string="Vans" name="vans" domain="[('vehicle_type', '=', 'van')]"/>
                <filter string="Reefers" name="reefers" domain="[('vehicle_type', '=', 'reefer')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="groupby_status" context="{'group_by': 'status'}"/>
                    <filter string="Type" name="groupby_type" context="{'group_by': 'vehicle_type'}"/>
                    <filter string="Home Depot" name="groupby_depot" context="{'group_by': 'home_depot'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ Vehicle Graph View ═══ -->
    <record id="view_transit_vehicle_graph" model="ir.ui.view">
        <field name="name">transit.vehicle.graph</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <graph string="Fleet Overview" type="pie">
                <field name="vehicle_type"/>
            </graph>
        </field>
    </record>

    <!-- ═══ Vehicle Pivot View ═══ -->
    <record id="view_transit_vehicle_pivot" model="ir.ui.view">
        <field name="name">transit.vehicle.pivot</field>
        <field name="model">transit.vehicle</field>
        <field name="arch" type="xml">
            <pivot string="Fleet Analysis">
                <field name="vehicle_type" type="row"/>
                <field name="status" type="col"/>
                <field name="odometer" type="measure"/>
                <field name="acquisition_cost" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══ Vehicle Action ═══ -->
    <record id="action_transit_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicle Registry</field>
        <field name="res_model">transit.vehicle</field>
        <field name="view_mode">kanban,tree,form,graph,pivot</field>
        <field name="search_view_id" ref="view_transit_vehicle_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first vehicle
            </p>
            <p>
                Add vehicles to your fleet registry to track status, trips, maintenance, and operational costs.
            </p>
        </field>
    </record>
</odoo>
